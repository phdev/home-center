{
  "items": [
    {
      "id": "p-essential-only",
      "text": "Show only the essential information at this moment. Every element on screen must justify its presence.",
      "added": "2026-04-21",
      "source": "seed"
    },
    {
      "id": "p-clarity-over-completeness",
      "text": "Clarity beats completeness \u2014 prefer leaving something out to crowding the primary signal.",
      "added": "2026-04-21",
      "source": "seed"
    },
    {
      "id": "p-glanceable",
      "text": "The primary signal must be readable in under two seconds from across a room.",
      "added": "2026-04-20",
      "source": "seed"
    },
    {
      "id": "p-one-primary",
      "text": "One primary thing, clearly, before any secondary things.",
      "added": "2026-04-20",
      "source": "seed"
    },
    {
      "id": "p-derived-state-drives-ui",
      "text": "Card visibility is driven by deterministic derived-state flags, never by LLM output.",
      "added": "2026-04-20",
      "source": "seed"
    },
    {
      "id": "p-actionable-over-informational",
      "text": "A prompt that produces a decision beats pure information.",
      "added": "2026-04-20",
      "source": "seed"
    },
    {
      "id": "p-avoid-patterns-that-make-the-interface-f",
      "text": "Avoid patterns that make the interface feel like a checklist app rather than a home.",
      "added": "2026-04-21",
      "source": "feedback"
    },
    {
      "id": "p-keep-the-screen-visually-concise",
      "text": "Keep the screen visually concise.",
      "added": "2026-04-22",
      "source": "telegram"
    },
    {
      "id": "p-prioritize-wind-down-items-for-tonight-o",
      "text": "Prioritize wind-down items for tonight only.",
      "added": "2026-04-22",
      "source": "telegram"
    },
    {
      "id": "p-priority-should-map-to-visual-position-i",
      "text": "Priority should map to visual position in the upper-left.",
      "added": "2026-04-25",
      "source": "telegram"
    },
    {
      "id": "p-avoid-excessive-internal-whitespace-in-c",
      "text": "Avoid excessive internal whitespace in card layouts.",
      "added": "2026-04-25",
      "source": "telegram"
    },
    {
      "id": "p-prioritized-cards-should-be-space-effici",
      "text": "Prioritized cards should be space-efficient.",
      "added": "2026-04-26",
      "source": "telegram"
    },
    {
      "id": "p-prioritize-dinner-first",
      "text": "Prioritize dinner first.",
      "added": "2026-05-03",
      "source": "telegram"
    }
  ]
