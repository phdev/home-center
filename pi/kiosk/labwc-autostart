# Home Center Kiosk Mode — labwc autostart
# Place at ~/.config/labwc/autostart on the Pi

# Disable screen blanking / DPMS
wlr-randr --output HDMI-A-1 --on --mode 3840x2160@60Hz --scale 1 2>/dev/null &

# Kill swayidle if running (prevent screen blanking)
killall swayidle 2>/dev/null

# Launch Chromium in kiosk mode
/usr/bin/chromium \
    --kiosk \
    --noerrdialogs --password-store=basic \
    --disable-infobars \
    --disable-session-crashed-bubble \
    --disable-restore-session-state \
    --no-first-run \
    --remote-debugging-address=127.0.0.1 \
    --remote-debugging-port=9222 \
    --start-fullscreen --disable-features=BlockInsecurePrivateNetworkRequests,PrivateNetworkAccessSendPreflights \
    --enable-features=OverlayScrollbar \
    --ozone-platform=wayland \
    --ignore-gpu-blocklist \
    --enable-gpu-rasterization \
    --enable-zero-copy \
    --num-raster-threads=4 \
    --force-device-scale-factor=2 \
    http://localhost:8080/home-center/ &
